# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection (Use MongoDB Atlas for production)
MONGODB_URI=mongodb://localhost:27017/military-asset-management

# JWT Secret (Generate a strong random string for production)
JWT_SECRET=your_jwt_secret_key_change_this_in_production

# Frontend URL (Update this with your Vercel deployment URL)
FRONTEND_URL=http://localhost:3000
